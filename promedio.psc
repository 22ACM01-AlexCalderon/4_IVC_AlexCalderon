Algoritmo Promedio
	Definir c Como Caracter
	Escribir "Ingrese una Clase: "
	leer c
	Definir n1, n2, n3, n4, n5 Como Real
	Escribir "Ingrese 5 notas: "
	leer n1
	leer n2
	leer n3
	leer n4
	leer n5
	Definir p Como Real
	p = (n1+n2+n3+n4+n5)/5
	Si p >= 70 Entonces
		Escribir "Gano la clase"
	SiNo
		Escribir "Perdio la clase"
	Fin Si
FinAlgoritmo
